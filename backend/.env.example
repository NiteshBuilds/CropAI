# ── Application ───────────────────────────────────────────────────────────────
APP_ENV=development
DEBUG=True

# ── Copernicus Data Space Ecosystem ──────────────────────────────────────────
# Register at: https://dataspace.copernicus.eu
COPERNICUS_USERNAME=
COPERNICUS_PASSWORD=

# ── Sentinel Hub OAuth 2.0 ────────────────────────────────────────────────────
# Register at: https://apps.sentinel-hub.com
SENTINEL_CLIENT_ID=
SENTINEL_CLIENT_SECRET=

# ── Open-Meteo Weather API (no account required) ──────────────────────────────
OPEN_METEO_BASE_URL=https://api.open-meteo.com/v1

# ── Geospatial Defaults ───────────────────────────────────────────────────────
DEFAULT_LATITUDE=
DEFAULT_LONGITUDE=
DEFAULT_AOI_RADIUS_KM=5

# ── CORS ──────────────────────────────────────────────────────────────────────
ALLOWED_ORIGINS=http://localhost:5173,http://localhost:3000


LOG_LEVEL=INFO
